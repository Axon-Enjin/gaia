# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Dev only: use Admin API for signup (no confirmation emails / no mailer rate limits).
# Set to "false" to use normal signUp even in development.
# SUPABASE_DEV_ADMIN_SIGNUP=true

# Azure AI Foundry (server-only)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2026-05-01
AZURE_OPENAI_DEPLOYMENT=gaia-gpt-5.4
AZURE_OPENAI_DEPLOYMENT_MINI=gaia-gpt-5.4-mini
# Local-dev fallback only; prefer DefaultAzureCredential in deployed environments.
# AZURE_OPENAI_API_KEY=

# Feature flags
ENABLE_AI_GENERATION=false
ENABLE_ONCHAIN_ANCHOR=false
