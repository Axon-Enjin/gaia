# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for POST /api/waitlist and dev Admin API signup bypass.
# Dev only: use Admin API for signup (no confirmation emails / no mailer rate limits).
# Set to "false" to use normal signUp even in development.
# SUPABASE_DEV_ADMIN_SIGNUP=true

# Azure AI Foundry (server-only)
# Resource host — client appends /openai/v1 when AZURE_OPENAI_API_KEY is set (Foundry dev).
# Project URL (reference only): https://gaia-llm-resource.services.ai.azure.com/api/projects/gaia-llm
AZURE_OPENAI_ENDPOINT=https://gaia-llm-resource.services.ai.azure.com
AZURE_OPENAI_API_VERSION=2026-05-01
AZURE_OPENAI_DEPLOYMENT=gaia-gpt-5.4
AZURE_OPENAI_DEPLOYMENT_MINI=gaia-gpt-5.4-mini
# Local-dev fallback only; prefer DefaultAzureCredential in deployed environments.
# AZURE_OPENAI_API_KEY=

# Feature flags
ENABLE_AI_GENERATION=false
ENABLE_ONCHAIN_ANCHOR=false
ENABLE_TESTNET_PAYOUT_DRILL=false

# Stellar Testnet anchor (server-only; create via: stellar keys generate aniskwela-anchor --network testnet --fund)
# STELLAR_ANCHOR_SECRET=S...
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# VC issuer signing key (server-only; Ed25519 PEM — generate locally, never commit)
# VC_ISSUER_DID=did:key:dev-aniskwela
# VC_ISSUER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Base URL for credential verify links + QR
NEXT_PUBLIC_APP_URL=http://localhost:3000
