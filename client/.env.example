# Aniskwela — environment contract
# Copy to .env.local and fill in values. Never commit .env.local.

# --- Supabase (public, browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server only) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Azure AI Foundry / OpenAI ---
# Required for AI course generation when ENABLE_AI_GENERATION=true
AZURE_OPENAI_ENDPOINT=
# Optional overrides (defaults in src/lib/env.ts)
AZURE_OPENAI_API_VERSION=2026-05-01
AZURE_OPENAI_DEPLOYMENT=aniskwela-gpt-5.4
AZURE_OPENAI_DEPLOYMENT_MINI=aniskwela-gpt-5.4-mini
# Local-dev fallback only; prefer DefaultAzureCredential (Managed Identity) in production
AZURE_OPENAI_API_KEY=

# --- Feature flags ---
ENABLE_AI_GENERATION=false
ENABLE_ONCHAIN_ANCHOR=false
